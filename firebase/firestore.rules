rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participants can create submissions — no read/update/delete from client
    match /submissions/{docId} {
      allow create: if request.resource.data.keys().hasAll(['utr', 'mobile', 'leaderEmail', 'submittedAt'])
        && request.resource.data.utr is string
        && request.resource.data.mobile is string
        && request.resource.data.leaderEmail is string;
      allow read, update, delete: if false;
    }
  }
}
